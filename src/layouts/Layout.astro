---
interface Props {
	title: string;
  description?: string;
  image?: string;
  type?: string;
}

const { 
  title, 
  description = "Desarrollador Web Full-Stack y Consultor de TI. Creando soluciones a medida, automatización de procesos y páginas web modernas para impulsar tu negocio.", 
  image = "/og-image.webp",
  type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="generator" content={Astro.generator} />
  
  <script is:inline>
    // Initialize theme based on preference or system settings
    (() => {
      const storedTheme = localStorage.getItem('theme');
      if (storedTheme) {
        document.documentElement.classList.add(storedTheme);
        document.documentElement.classList.remove(storedTheme === 'dark' ? 'light' : 'dark');
      } else {
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const defaultTheme = systemPrefersDark ? 'dark' : 'light';
        document.documentElement.classList.add(defaultTheme);
        document.documentElement.classList.remove(defaultTheme === 'dark' ? 'light' : 'dark');
      }
    })();
  </script>
  
  <!-- SEO Básico -->
	<title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Devcito" />
  <meta name="keywords" content="desarrollador web, full-stack, automatización de procesos, consultoría ti, diseño web, desarrollo de software, landing pages, devcito" />
  <meta name="robots" content="index, follow" />
  <!-- Theme Color para móviles -->
  <meta name="theme-color" content="#030712" />

  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, canonicalURL)} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, canonicalURL)} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      /* Shared fonts */
      --font-primary: 'Outfit', sans-serif;
      --font-display: 'Outfit', sans-serif;
      
      /* Theme transition */
      --theme-transition: background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
                         color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                         border-color 0.3s ease,
                         box-shadow 0.3s ease;
    }

    /* Light Theme */
    html.light {
      --color-bg-primary: #ffffff;
      --color-bg-secondary: #f8fafc;
      --color-bg-tertiary: #f1f5f9;
      --color-text-primary: #0f172a;
      --color-text-secondary: #475569;
      --color-text-muted: #64748b;
      --color-border: rgba(15, 23, 42, 0.08);
      --color-card-bg: rgba(255, 255, 255, 0.85);
      --color-card-border: rgba(15, 23, 42, 0.05);

      /* Monochromatic Blues: Deep Blue, Royal Blue, Sky Blue */
      --color-cyan: #0284c7;      /* Ocean Blue */
      --color-blue: #2563eb;      /* Royal Blue */
      --color-purple: #0ea5e9;    /* Sky Blue */
      --color-pink: #1e40af;      /* Deep Cobalt Blue */
      --color-sky: #0ea5e9;       /* Sky Blue */

      --color-accent-shadow: rgba(37, 99, 235, 0.15);
      --color-accent-glow: rgba(37, 99, 235, 0.06);
      --color-accent-soft: rgba(37, 99, 235, 0.04);

      --color-cyan-glow: rgba(2, 132, 199, 0.07);
      --color-blue-glow: rgba(37, 99, 235, 0.06);
      --color-purple-glow: rgba(14, 165, 233, 0.05);

      --gradient-glow-top: rgba(37, 99, 235, 0.04);
      --gradient-glow-right: rgba(14, 165, 233, 0.03);
      --gradient-glow-left: rgba(56, 189, 248, 0.03);
      --gradient-body-orb: rgba(37, 99, 235, 0.03);

      --scroll-track: #f1f5f9;
      --scroll-thumb-start: #0284c7;
      --scroll-thumb-end: #0ea5e9;
      
      --bg-dots: url("data:image/svg+xml,%3csvg width='32' height='32' viewBox='0 0 32 32' xmlns='http://www.w3.org/2000/svg'%3e%3ccircle cx='1' cy='1' r='0.6' fill='rgba(37,99,235,0.03)'/%3e%3c/svg%3e");
      --grid-line-color: rgba(37, 99, 235, 0.015);
      --grid-dot-opacity: 0.015;
    }

    /* Dark Theme */
    html.dark {
      --color-bg-primary: #020617; /* Deep Slate/Navy Black */
      --color-bg-secondary: #0b0f19;
      --color-bg-tertiary: #131a26;
      --color-text-primary: #f8fafc;
      --color-text-secondary: #94a3b8;
      --color-text-muted: #64748b;
      --color-border: rgba(255, 255, 255, 0.08);
      --color-card-bg: rgba(11, 15, 25, 0.65);
      --color-card-border: rgba(255, 255, 255, 0.05);

      /* Electric Cyan & Ocean Blues (NO purple, NO green, NO pink) */
      --color-cyan: #00f5ff;      /* Electric Cyan */
      --color-blue: #38bdf8;      /* Sky Blue */
      --color-purple: #2563eb;    /* Royal Blue */
      --color-pink: #1d4ed8;      /* Cobalt Blue */
      --color-sky: #38bdf8;       /* Sky Blue */

      --color-accent-shadow: rgba(0, 245, 255, 0.3);
      --color-accent-glow: rgba(0, 245, 255, 0.15);
      --color-accent-soft: rgba(0, 245, 255, 0.06);

      --color-cyan-glow: rgba(0, 245, 255, 0.15);
      --color-blue-glow: rgba(56, 189, 248, 0.12);
      --color-purple-glow: rgba(37, 99, 235, 0.12);

      --gradient-glow-top: rgba(0, 245, 255, 0.12);
      --gradient-glow-right: rgba(14, 165, 233, 0.08);
      --gradient-glow-left: rgba(59, 130, 246, 0.08);
      --gradient-body-orb: rgba(0, 245, 255, 0.06);

      --scroll-track: #020617;
      --scroll-thumb-start: #00f5ff;
      --scroll-thumb-end: #3b82f6;

      --bg-dots: url("data:image/svg+xml,%3csvg width='32' height='32' viewBox='0 0 32 32' xmlns='http://www.w3.org/2000/svg'%3e%3ccircle cx='1' cy='1' r='0.6' fill='rgba(0,245,255,0.02)'/%3e%3c/svg%3e");
      --grid-line-color: rgba(0, 245, 255, 0.025);
      --grid-dot-opacity: 0.02;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      background-color: var(--color-bg-primary);
      font-family: var(--font-primary);
      transition: var(--theme-transition);
    }

    body {
      background-color: var(--color-bg-primary);
      background-image:
        radial-gradient(ellipse 80% 50% at 50% -20%, var(--gradient-body-orb), transparent),
        var(--bg-dots);
      color: var(--color-text-primary);
      overflow-x: hidden;
      transition: var(--theme-transition);
    }

    /* =================================
       CUSTOM CURSOR (HIGH-TECH DYNAMIC GLOW)
       ================================= */
    #cursor-outer {
      position: fixed;
      top: 0;
      left: 0;
      width: 28px;
      height: 28px;
      border: 2px solid var(--color-cyan);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transition: border-color 0.25s cubic-bezier(0.25, 1, 0.5, 1), 
                  width 0.25s cubic-bezier(0.25, 1, 0.5, 1), 
                  height 0.25s cubic-bezier(0.25, 1, 0.5, 1), 
                  background-color 0.25s cubic-bezier(0.25, 1, 0.5, 1), 
                  box-shadow 0.25s cubic-bezier(0.25, 1, 0.5, 1);
      mix-blend-mode: difference;
      transform: translate3d(-100px, -100px, 0);
      box-shadow: 0 0 8px var(--color-cyan);
    }

    #cursor-outer::after {
      content: '';
      position: absolute;
      inset: -6px;
      border: 1px dashed var(--color-cyan);
      border-radius: 50%;
      opacity: 0;
      transition: opacity 0.25s ease, border-color 0.25s ease;
    }

    body.cursor-hover #cursor-outer {
      width: 48px;
      height: 48px;
      border-color: var(--color-cyan);
      background-color: var(--color-accent-soft);
      box-shadow: 0 0 20px var(--color-accent-glow);
    }

    body.cursor-hover #cursor-outer::after {
      border-color: var(--color-cyan);
      opacity: 1;
      animation: cursor-spin 6s linear infinite;
    }

    body.cursor-clicking #cursor-outer {
      width: 20px;
      height: 20px;
      border-color: var(--color-cyan);
      background-color: var(--color-accent-glow);
      box-shadow: 0 0 25px var(--color-cyan);
    }
    
    body.cursor-clicking #cursor-outer::after {
      opacity: 0;
      transform: scale(0.5);
    }

    @keyframes cursor-spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @media (hover: none) {
      #cursor-outer {
        display: none;
      }
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--scroll-track); }
    ::-webkit-scrollbar-thumb {
      background: linear-gradient(to bottom, var(--scroll-thumb-start), var(--scroll-thumb-end));
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: linear-gradient(to bottom, var(--scroll-thumb-end), var(--scroll-thumb-start));
    }

    /* Scroll progress bar */
    #scroll-progress {
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--color-cyan), var(--color-blue), var(--color-purple), var(--color-cyan));
      background-size: 300% 100%;
      box-shadow: 0 0 12px var(--color-cyan);
      z-index: 1000;
      transform-origin: left;
      width: 0%;
      transition: none;
      animation: progress-flow 4s linear infinite;
    }

    @keyframes progress-flow {
      0% { background-position: 0% 0%; }
      100% { background-position: 300% 0%; }
    }

		/* Fade-in base (scroll reveal) */
    .fade-in-element {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1), transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in-element.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .fade-in-left,
    .fade-slide-left {
      opacity: 0;
      transform: translateX(-35px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in-left.is-visible,
    .fade-slide-left.is-visible {
      opacity: 1;
      transform: translateX(0);
    }
    .fade-slide-right {
      opacity: 0;
      transform: translateX(35px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-slide-right.is-visible {
      opacity: 1;
      transform: translateX(0);
    }

    /* Sections: offset for fixed header */
    section[id] { scroll-margin-top: 80px; }

    /* Gradient text utility */
    .gradient-text {
      background: linear-gradient(135deg, var(--color-cyan), var(--color-blue), var(--color-purple));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Section titles */
    .section-title {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(1.9rem, 4vw, 2.75rem);
      font-weight: 800;
      text-align: center;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, var(--color-text-primary) 0%, var(--color-cyan) 60%, var(--color-blue) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.02em;
    }
    .section-subtitle {
      font-size: 1rem;
      color: var(--color-text-secondary);
      text-align: center;
      margin-bottom: 4rem;
      max-width: 580px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.7;
    }

    @media (max-width: 768px) {
      .section-subtitle { font-size: 0.9rem; margin-bottom: 2.5rem; }
    }
	</style>
</head>
<body>
  <!-- Custom cursor -->
  <div id="cursor-outer"></div>

  <!-- Scroll progress bar -->
  <div id="scroll-progress"></div>

	<slot />

  <script>
    // === CUSTOM CURSOR ===
    const outer = document.getElementById('cursor-outer');
    let outerX = 0, outerY = 0;
    let targetX = -100, targetY = -100;
    let isInitialized = false;

    document.addEventListener('mousemove', (e) => {
      targetX = e.clientX;
      targetY = e.clientY;
      if (!isInitialized) {
        outerX = targetX;
        outerY = targetY;
        isInitialized = true;
      }
    });

    document.addEventListener('mousedown', () => {
      document.body.classList.add('cursor-clicking');
    });
    
    document.addEventListener('mouseup', () => {
      document.body.classList.remove('cursor-clicking');
    });

    // Smooth lag for outer cursor with velocity-based stretching
    const animateCursor = () => {
      if (isInitialized && outer) {
        const dx = targetX - outerX;
        const dy = targetY - outerY;
        
        outerX += dx * 0.12;
        outerY += dy * 0.12;

        const velocity = Math.sqrt(dx * dx + dy * dy);
        const angle = Math.atan2(dy, dx) * (180 / Math.PI);
        
        // Stretch based on velocity, limit maximum stretch to 40%
        const stretch = Math.min(velocity * 0.015, 0.4);
        const scaleX = 1 + stretch;
        const scaleY = 1 - stretch;

        outer.style.transform = `translate3d(${outerX}px, ${outerY}px, 0) translate3d(-50%, -50%, 0) rotate(${angle}deg) scale(${scaleX}, ${scaleY})`;
      }
      requestAnimationFrame(animateCursor);
    };
    animateCursor();

    // Hover effect
    const hoverEls = document.querySelectorAll('a, button, [data-tilt], .skill-chip, .tech-pill');
    hoverEls.forEach(el => {
      el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
      el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
    });

    // === SCROLL PROGRESS ===
    const progress = document.getElementById('scroll-progress')!;
    window.addEventListener('scroll', () => {
      const scrollTop = document.documentElement.scrollTop;
      const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      progress.style.width = `${(scrollTop / scrollHeight) * 100}%`;
    }, { passive: true });

    // === SCROLL REVEAL ===
    document.addEventListener('DOMContentLoaded', () => {
      const sections = document.querySelectorAll('section');
      sections.forEach(section => {
        const items = section.querySelectorAll('.fade-in-element, .fade-in-left');
        items.forEach((el, i) => {
          (el as HTMLElement).style.transitionDelay = `${i * 0.08}s`;
        });
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });

      const elementsToFadeIn = document.querySelectorAll('.fade-in-element, .fade-in-left, .fade-slide-left, .fade-slide-right');
      elementsToFadeIn.forEach(el => observer.observe(el));
    });
  </script>
</body>
</html>
